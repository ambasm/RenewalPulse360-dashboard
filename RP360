<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RenewalPulse 360 — Customer Health Platform</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:   #0D1F3C;
    --teal:   #0A8A7A;
    --teal2:  #0CC9AE;
    --amber:  #F4A024;
    --red:    #E84545;
    --green:  #22C55E;
    --ice:    #E8F6F5;
    --white:  #FFFFFF;
    --muted:  #64748B;
    --border: rgba(10,138,122,0.18);
    --card:   rgba(255,255,255,0.97);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #0B1629;
    color: #E2E8F0;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── MESH BACKGROUND ── */
  body::before {
    content:'';
    position:fixed; inset:0; z-index:0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 20%, rgba(10,138,122,.22) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 90% 80%, rgba(12,201,174,.10) 0%, transparent 55%),
      radial-gradient(ellipse 40% 35% at 50% 50%, rgba(13,31,60,.9) 0%, transparent 100%);
    pointer-events:none;
  }

  /* ── LAYOUT ── */
  .shell { position:relative; z-index:1; display:flex; min-height:100vh; }

  /* ── SIDEBAR ── */
  .sidebar {
    width:220px; flex-shrink:0;
    background: rgba(13,31,60,0.85);
    backdrop-filter: blur(12px);
    border-right: 1px solid var(--border);
    display:flex; flex-direction:column;
    padding:28px 0; position:sticky; top:0; height:100vh;
  }

  .sidebar-logo {
    padding: 0 22px 28px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-logo .brand {
    font-family:'DM Serif Display', serif;
    font-size:1.15rem; color:var(--teal2);
    letter-spacing:-.01em; line-height:1.1;
  }
  .sidebar-logo .sub { font-size:.72rem; color:var(--muted); margin-top:2px; }

  .nav { flex:1; padding:18px 0; }
  .nav-item {
    display:flex; align-items:center; gap:10px;
    padding:10px 22px; font-size:.85rem; font-weight:500;
    color:#94A3B8; cursor:pointer; border-left:3px solid transparent;
    transition:all .2s;
  }
  .nav-item:hover { color:#E2E8F0; background:rgba(10,138,122,.1); }
  .nav-item.active {
    color:var(--teal2); border-left-color:var(--teal2);
    background:rgba(12,201,174,.08);
  }
  .nav-icon { font-size:1rem; width:18px; text-align:center; }

  .sidebar-footer {
    padding:18px 22px;
    border-top:1px solid var(--border);
    font-size:.76rem; color:var(--muted);
  }
  .status-dot {
    display:inline-block; width:7px; height:7px;
    border-radius:50%; background:var(--green);
    margin-right:5px; animation:pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }

  /* ── MAIN ── */
  .main { flex:1; padding:32px 36px; overflow-y:auto; }

  /* ── TOPBAR ── */
  .topbar {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:28px;
  }
  .page-title { font-family:'DM Serif Display',serif; font-size:1.6rem; color:#F0F9FF; }
  .page-sub { font-size:.82rem; color:var(--muted); margin-top:2px; }

  .topbar-actions { display:flex; gap:10px; align-items:center; }
  .btn {
    padding:8px 16px; border-radius:8px; font-size:.82rem; font-weight:500;
    cursor:pointer; border:none; transition:all .2s;
  }
  .btn-ghost {
    background:rgba(255,255,255,.07); color:#CBD5E1;
    border:1px solid var(--border);
  }
  .btn-ghost:hover { background:rgba(255,255,255,.12); }
  .btn-primary {
    background: linear-gradient(135deg, var(--teal), var(--teal2));
    color:#fff;
  }
  .btn-primary:hover { filter:brightness(1.1); transform:translateY(-1px); }

  /* ── KPI CARDS ── */
  .kpi-grid {
    display:grid; grid-template-columns:repeat(4,1fr); gap:16px;
    margin-bottom:28px;
  }
  .kpi-card {
    background: var(--card);
    border-radius:14px; padding:20px 22px;
    border:1px solid rgba(10,138,122,.12);
    position:relative; overflow:hidden;
    animation: fadeUp .5s both;
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
  .kpi-card:nth-child(1){animation-delay:.05s}
  .kpi-card:nth-child(2){animation-delay:.10s}
  .kpi-card:nth-child(3){animation-delay:.15s}
  .kpi-card:nth-child(4){animation-delay:.20s}

  .kpi-card::after {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    border-radius:14px 14px 0 0;
  }
  .kpi-card.g::after { background:var(--green); }
  .kpi-card.a::after { background:var(--amber); }
  .kpi-card.r::after { background:var(--red); }
  .kpi-card.t::after { background:var(--teal2); }

  .kpi-label { font-size:.75rem; color:var(--muted); font-weight:500; letter-spacing:.04em; text-transform:uppercase; }
  .kpi-value { font-size:2rem; font-weight:700; color:var(--navy); margin:4px 0 2px; line-height:1; }
  .kpi-delta { font-size:.78rem; }
  .kpi-delta.up { color:var(--green); }
  .kpi-delta.dn { color:var(--red); }

  /* ── CONTENT GRID ── */
  .content-grid {
    display:grid; grid-template-columns:1.55fr 1fr; gap:20px;
    margin-bottom:20px;
  }

  /* ── PANEL ── */
  .panel {
    background: rgba(13,31,60,0.7);
    backdrop-filter:blur(10px);
    border:1px solid var(--border);
    border-radius:16px; padding:22px;
    animation: fadeUp .55s .25s both;
  }
  .panel-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:18px;
  }
  .panel-title { font-family:'DM Serif Display',serif; font-size:1.05rem; color:#F0F9FF; }
  .panel-sub { font-size:.74rem; color:var(--muted); margin-top:2px; }
  .badge {
    padding:3px 10px; border-radius:20px; font-size:.72rem; font-weight:600;
  }
  .badge-teal { background:rgba(12,201,174,.15); color:var(--teal2); }
  .badge-red  { background:rgba(232,69,69,.15);  color:var(--red); }
  .badge-amber{ background:rgba(244,160,36,.15);  color:var(--amber); }

  /* ── ACCOUNT TABLE ── */
  .acct-table { width:100%; border-collapse:collapse; }
  .acct-table th {
    font-size:.72rem; text-transform:uppercase; letter-spacing:.06em;
    color:var(--muted); padding:8px 10px; text-align:left;
    border-bottom:1px solid var(--border);
  }
  .acct-table td { padding:11px 10px; font-size:.84rem; border-bottom:1px solid rgba(255,255,255,.04); }
  .acct-table tr:hover td { background:rgba(10,138,122,.06); }
  .acct-table tr:last-child td { border:none; }

  .score-pill {
    display:inline-flex; align-items:center; justify-content:center;
    width:42px; height:24px; border-radius:6px;
    font-size:.78rem; font-weight:700;
  }
  .score-pill.high   { background:rgba(34,197,94,.15);  color:#4ADE80; }
  .score-pill.medium { background:rgba(244,160,36,.15); color:#FBBF24; }
  .score-pill.low    { background:rgba(232,69,69,.15);  color:#F87171; }

  .risk-bar-wrap { display:flex; align-items:center; gap:8px; }
  .risk-bar { height:6px; border-radius:3px; background:rgba(255,255,255,.1); flex:1; }
  .risk-fill { height:6px; border-radius:3px; }

  .acct-name { font-weight:600; color:#E2E8F0; }
  .acct-arr  { color:#94A3B8; font-size:.8rem; }
  .tier-chip {
    font-size:.68rem; padding:2px 8px; border-radius:20px; font-weight:600;
  }
  .tier-ent  { background:rgba(244,160,36,.15); color:var(--amber); }
  .tier-mid  { background:rgba(10,138,122,.15);  color:var(--teal2); }

  /* ── HEALTH GAUGE ── */
  .gauge-wrap { display:flex; flex-direction:column; align-items:center; padding:12px 0 4px; }
  .gauge-svg { width:180px; }
  .gauge-score { font-family:'DM Serif Display',serif; font-size:2.6rem; fill:#F0F9FF; }
  .gauge-label-text { font-size:.9rem; fill:#64748B; }
  .gauge-legend { display:flex; gap:16px; margin-top:14px; flex-wrap:wrap; justify-content:center; }
  .legend-item { display:flex; align-items:center; gap:6px; font-size:.76rem; color:#94A3B8; }
  .legend-dot { width:8px; height:8px; border-radius:50%; }

  /* ── SIGNALS ── */
  .signal-list { display:flex; flex-direction:column; gap:10px; }
  .signal-item {
    display:flex; gap:12px; align-items:flex-start;
    padding:12px 14px; border-radius:10px; background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.06); cursor:pointer;
    transition:all .2s;
  }
  .signal-item:hover { background:rgba(10,138,122,.1); border-color:var(--border); }
  .signal-icon {
    width:32px; height:32px; border-radius:8px;
    display:flex; align-items:center; justify-content:center; font-size:.95rem; flex-shrink:0;
  }
  .signal-icon.red   { background:rgba(232,69,69,.15); }
  .signal-icon.amber { background:rgba(244,160,36,.15); }
  .signal-icon.teal  { background:rgba(12,201,174,.15); }
  .signal-title { font-size:.84rem; font-weight:600; color:#E2E8F0; }
  .signal-desc  { font-size:.76rem; color:#94A3B8; margin-top:2px; line-height:1.4; }
  .signal-meta  { margin-left:auto; font-size:.71rem; color:var(--muted); white-space:nowrap; }

  /* ── PLAYBOOK ── */
  .playbook-list { display:flex; flex-direction:column; gap:8px; }
  .playbook-item {
    display:flex; align-items:center; gap:10px;
    padding:10px 14px; border-radius:10px;
    background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.05);
    font-size:.82rem; cursor:pointer; transition:all .2s;
  }
  .playbook-item:hover { background:rgba(10,138,122,.09); }
  .pb-num {
    width:22px; height:22px; border-radius:6px;
    background: linear-gradient(135deg,var(--teal),var(--teal2));
    color:#fff; font-size:.72rem; font-weight:700;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .pb-label { flex:1; color:#CBD5E1; }
  .pb-action {
    font-size:.72rem; padding:3px 9px; border-radius:6px; font-weight:600;
    background:rgba(10,138,122,.18); color:var(--teal2); border:none; cursor:pointer;
    transition:all .2s;
  }
  .pb-action:hover { background:rgba(10,138,122,.35); }

  /* ── MINI CHART (CSS bars) ── */
  .mini-chart { display:flex; align-items:flex-end; gap:4px; height:60px; padding-top:8px; }
  .bar-wrap { display:flex; flex-direction:column; align-items:center; gap:4px; flex:1; }
  .bar {
    width:100%; border-radius:4px 4px 0 0;
    background: linear-gradient(180deg,var(--teal2),var(--teal));
    transition:height .5s ease;
  }
  .bar-label { font-size:.65rem; color:var(--muted); }

  /* ── ARR AT-RISK ── */
  .arr-blocks { display:flex; gap:10px; flex-wrap:wrap; margin-top:6px; }
  .arr-block {
    flex:1; min-width:80px; border-radius:10px; padding:14px 12px;
    text-align:center;
  }
  .arr-block.red   { background:rgba(232,69,69,.12);  border:1px solid rgba(232,69,69,.25); }
  .arr-block.amber { background:rgba(244,160,36,.12); border:1px solid rgba(244,160,36,.25); }
  .arr-block.green { background:rgba(34,197,94,.12);  border:1px solid rgba(34,197,94,.25); }
  .arr-num  { font-size:1.3rem; font-weight:700; font-family:'DM Serif Display',serif; }
  .arr-blk-label { font-size:.7rem; color:var(--muted); margin-top:2px; }

  /* ── FOOTER ── */
  .footer {
    margin-top:10px; padding-top:16px;
    border-top:1px solid var(--border);
    font-size:.72rem; color:var(--muted);
    display:flex; justify-content:space-between; align-items:center;
  }

  /* ── MODAL-STYLE DETAIL PANEL ── */
  #detail-panel {
    position:fixed; right:0; top:0; bottom:0; width:360px;
    background: rgba(11,22,41,0.97);
    backdrop-filter:blur(16px);
    border-left:1px solid var(--border);
    z-index:100; padding:28px 24px;
    transform:translateX(110%); transition:transform .35s cubic-bezier(.4,0,.2,1);
    overflow-y:auto;
  }
  #detail-panel.open { transform:translateX(0); }
  .dp-close {
    position:absolute; top:18px; right:18px;
    background:rgba(255,255,255,.07); border:none; color:#94A3B8;
    width:28px; height:28px; border-radius:7px; cursor:pointer; font-size:1rem;
    transition:all .2s;
  }
  .dp-close:hover { background:rgba(232,69,69,.2); color:var(--red); }
  .dp-title { font-family:'DM Serif Display',serif; font-size:1.2rem; color:#F0F9FF; }
  .dp-arr { font-size:.8rem; color:var(--muted); margin-top:2px; }
  .dp-section { margin-top:20px; }
  .dp-section-title { font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:10px; }
  .driver-row { display:flex; align-items:center; gap:10px; margin-bottom:9px; }
  .driver-label { font-size:.8rem; color:#CBD5E1; width:120px; flex-shrink:0; }
  .driver-bar-wrap { flex:1; height:8px; background:rgba(255,255,255,.1); border-radius:4px; }
  .driver-fill { height:8px; border-radius:4px; }
  .driver-val { font-size:.76rem; font-weight:700; width:30px; text-align:right; }
  .rec-item {
    padding:10px 12px; border-radius:8px; background:rgba(10,138,122,.1);
    border:1px solid rgba(10,138,122,.2); margin-bottom:8px;
    font-size:.8rem; color:#CBD5E1; line-height:1.45;
  }
  .rec-item strong { color:var(--teal2); }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width:5px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:rgba(10,138,122,.3); border-radius:10px; }

  /* ── RESPONSIVE ── */
  @media(max-width:1100px) {
    .kpi-grid { grid-template-columns:repeat(2,1fr); }
    .content-grid { grid-template-columns:1fr; }
  }
</style>
</head>
<body>

<div class="shell">

  <!-- ── SIDEBAR ── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="brand">RenewalPulse<br>360</div>
      <div class="sub">Customer Health Platform</div>
    </div>

    <nav class="nav">
      <div class="nav-item active" onclick="setPage(this,'portfolio')">
        <span class="nav-icon">◈</span> Portfolio
      </div>
      <div class="nav-item" onclick="setPage(this,'signals')">
        <span class="nav-icon">⚡</span> Live Signals
      </div>
      <div class="nav-item" onclick="setPage(this,'playbooks')">
        <span class="nav-icon">▶</span> Playbooks
      </div>
      <div class="nav-item" onclick="setPage(this,'pipeline')">
        <span class="nav-icon">⤷</span> Data Pipeline
      </div>
      <div class="nav-item" onclick="setPage(this,'settings')">
        <span class="nav-icon">⚙</span> Settings
      </div>
    </nav>

    <div class="sidebar-footer">
      <span class="status-dot"></span>Live · Updated 4 min ago<br>
      <span style="margin-top:4px;display:block">Model v2.3.1 · Pilot R2</span>
    </div>
  </aside>

  <!-- ── MAIN ── -->
  <main class="main">
    <div class="topbar">
      <div>
        <div class="page-title" id="page-title">Portfolio Overview</div>
        <div class="page-sub">18 accounts · CSM view</div>
      </div>
      <div class="topbar-actions">
        <button class="btn btn-ghost">⬇ Export</button>
        <button class="btn btn-primary" onclick="openDetail('new')">+ Run Playbook</button>
      </div>
    </div>

    <!-- KPIs -->
    <div class="kpi-grid">
      <div class="kpi-card g">
        <div class="kpi-label">Portfolio Health</div>
        <div class="kpi-value" style="color:#22C55E">74</div>
        <div class="kpi-delta up">↑ 6 pts vs last sprint</div>
      </div>
      <div class="kpi-card r">
        <div class="kpi-label">ARR at Risk</div>
        <div class="kpi-value" style="color:#E84545">$1.2M</div>
        <div class="kpi-delta dn">↓ 3 accounts high-risk</div>
      </div>
      <div class="kpi-card a">
        <div class="kpi-label">Renewal Probability</div>
        <div class="kpi-value" style="color:#F4A024">81%</div>
        <div class="kpi-delta up">↑ 4% since R1</div>
      </div>
      <div class="kpi-card t">
        <div class="kpi-label">Open Alerts</div>
        <div class="kpi-value" style="color:#0CC9AE">7</div>
        <div class="kpi-delta dn">3 critical, 4 warning</div>
      </div>
    </div>

    <!-- Main content grid -->
    <div class="content-grid">

      <!-- Left: Account table -->
      <div class="panel">
        <div class="panel-header">
          <div>
            <div class="panel-title">Account Health Scores</div>
            <div class="panel-sub">Sorted by renewal risk · Click row for detail</div>
          </div>
          <span class="badge badge-teal">18 accounts</span>
        </div>

        <table class="acct-table">
          <thead>
            <tr>
              <th>Account</th>
              <th>Score</th>
              <th>Renewal Risk</th>
              <th>ARR</th>
              <th>Tier</th>
            </tr>
          </thead>
          <tbody id="acct-tbody"></tbody>
        </table>
      </div>

      <!-- Right column -->
      <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Portfolio gauge -->
        <div class="panel">
          <div class="panel-header">
            <div class="panel-title">Portfolio Health</div>
            <span class="badge badge-teal">All accounts</span>
          </div>
          <div class="gauge-wrap">
            <svg class="gauge-svg" viewBox="0 0 200 130" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- track -->
              <path d="M 20 110 A 80 80 0 0 1 180 110" stroke="rgba(255,255,255,.1)" stroke-width="14" stroke-linecap="round"/>
              <!-- green zone -->
              <path d="M 20 110 A 80 80 0 0 1 100 30" stroke="#22C55E" stroke-width="14" stroke-linecap="round" opacity=".5"/>
              <!-- amber zone -->
              <path d="M 100 30 A 80 80 0 0 1 180 110" stroke="#F4A024" stroke-width="14" stroke-linecap="round" opacity=".3"/>
              <!-- needle fill to 74% -->
              <path d="M 20 110 A 80 80 0 0 1 164 68" stroke="url(#gaugeGrad)" stroke-width="14" stroke-linecap="round"/>
              <defs>
                <linearGradient id="gaugeGrad" x1="20" y1="110" x2="164" y2="68" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#22C55E"/>
                  <stop offset="100%" stop-color="#0CC9AE"/>
                </linearGradient>
              </defs>
              <!-- needle dot -->
              <circle cx="164" cy="68" r="7" fill="#0CC9AE"/>
              <!-- score text -->
              <text x="100" y="100" text-anchor="middle" class="gauge-score" font-family="DM Serif Display,serif" font-size="32" fill="#F0F9FF">74</text>
              <text x="100" y="118" text-anchor="middle" class="gauge-label-text" font-size="11" fill="#64748B">/100 Portfolio Score</text>
            </svg>
            <div class="gauge-legend">
              <div class="legend-item"><div class="legend-dot" style="background:#22C55E"></div>Healthy (60–100)</div>
              <div class="legend-item"><div class="legend-dot" style="background:#F4A024"></div>At-risk (35–59)</div>
              <div class="legend-item"><div class="legend-dot" style="background:#E84545"></div>Critical (&lt;35)</div>
            </div>
          </div>
        </div>

        <!-- ARR breakdown -->
        <div class="panel">
          <div class="panel-header">
            <div class="panel-title">ARR Forecast</div>
            <span class="badge badge-amber">Weekly view</span>
          </div>
          <div class="arr-blocks">
            <div class="arr-block green">
              <div class="arr-num" style="color:#4ADE80">$5.8M</div>
              <div class="arr-blk-label">Safe</div>
            </div>
            <div class="arr-block amber">
              <div class="arr-num" style="color:#FBBF24">$1.9M</div>
              <div class="arr-blk-label">Watching</div>
            </div>
            <div class="arr-block red">
              <div class="arr-num" style="color:#F87171">$1.2M</div>
              <div class="arr-blk-label">At Risk</div>
            </div>
          </div>
          <div style="margin-top:16px">
            <div style="font-size:.74rem;color:var(--muted);margin-bottom:6px">Weekly renewal volume ($K)</div>
            <div class="mini-chart" id="mini-chart"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom row: signals + playbooks -->
    <div class="content-grid">
      <div class="panel">
        <div class="panel-header">
          <div>
            <div class="panel-title">Live Risk Signals</div>
            <div class="panel-sub">Ingested from CRM · Support · Telemetry · Billing</div>
          </div>
          <span class="badge badge-red">7 active</span>
        </div>
        <div class="signal-list" id="signal-list"></div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <div>
            <div class="panel-title">Intervention Playbooks</div>
            <div class="panel-sub">AI-recommended actions</div>
          </div>
          <span class="badge badge-teal">Ready</span>
        </div>
        <div class="playbook-list" id="playbook-list"></div>
      </div>
    </div>

    <div class="footer">
      <span>RenewalPulse 360 v1.0</span>
      <span>Data freshness: &lt;24h · Model: XGBoost + SHAP · Uptime: 99.9%</span>
    </div>

  </main>
</div>

<!-- ── DETAIL PANEL ── -->
<div id="detail-panel">
  <button class="dp-close" onclick="closeDetail()">✕</button>
  <div id="dp-content"></div>
</div>

<script>
/* ─── DATA ─── */
const accounts = [
  { id:1, name:'Meridian Financial',  score:18, risk:87, arr:'$520K', tier:'Enterprise', renewal:'21 days' },
  { id:2, name:'Apex Logistics',      score:24, risk:79, arr:'$310K', tier:'Enterprise', renewal:'34 days' },
  { id:3, name:'ClearVision SaaS',    score:31, risk:68, arr:'$195K', tier:'Mid-Market', renewal:'41 days' },
  { id:4, name:'Orion Healthcare',    score:45, risk:52, arr:'$440K', tier:'Enterprise', renewal:'58 days' },
  { id:5, name:'Stellar EdTech',      score:52, risk:44, arr:'$120K', tier:'Mid-Market', renewal:'63 days' },
  { id:6, name:'NovaBridge Corp',     score:61, risk:32, arr:'$280K', tier:'Enterprise', renewal:'77 days' },
  { id:7, name:'Quantum Retail',      score:68, risk:26, arr:'$150K', tier:'Mid-Market', renewal:'89 days' },
  { id:8, name:'BluePeak Analytics',  score:74, risk:20, arr:'$370K', tier:'Enterprise', renewal:'95 days' },
  { id:9, name:'Zephyr Payments',     score:79, risk:14, arr:'$210K', tier:'Mid-Market', renewal:'112 days'},
  { id:10,name:'Cascade Telecom',     score:85, risk:8,  arr:'$490K', tier:'Enterprise', renewal:'120 days'},
];

const signals = [
  { type:'red',   icon:'⚠',  title:'Meridian Financial — Critical drop',    desc:'Product usage fell 62% over 14 days. 3 key features unused this month.', time:'2h ago' },
  { type:'red',   icon:'💳', title:'Apex Logistics — Payment delinquency',   desc:'Invoice overdue 18 days. Billing team flagged for escalation.', time:'5h ago' },
  { type:'amber', icon:'🎫', title:'ClearVision — High ticket volume',        desc:'8 unresolved P1 tickets. NPS dropped 22 pts in last survey.', time:'8h ago' },
  { type:'amber', icon:'👥', title:'Orion Healthcare — Champion left',        desc:'Primary buyer (VP Ops) departed. No successor identified yet.', time:'1d ago' },
  { type:'amber', icon:'📉', title:'Stellar EdTech — Seat utilisation low',   desc:'Only 41% of licensed seats active. Risk of downsell at renewal.', time:'2d ago' },
  { type:'teal',  icon:'✅', title:'Cascade Telecom — QBR completed',         desc:'Exec sponsor confirmed value. Expansion opportunity identified.', time:'3d ago' },
];

const playbooks = [
  { num:1, label:'Schedule executive recovery call — Meridian Financial' },
  { num:2, label:'Issue credit memo + billing escalation — Apex Logistics' },
  { num:3, label:'Assign dedicated CSE for P1 backlog — ClearVision' },
  { num:4, label:'Identify new champion + onboarding — Orion Healthcare' },
  { num:5, label:'Run adoption workshop (unused features) — Stellar EdTech' },
];

const chartBars = [62,78,55,91,43,80,72,95,60,85,74,88];
const chartLabels = ['W1','W2','W3','W4','W5','W6','W7','W8','W9','W10','W11','W12'];

const drivers = {
  positive: [
    { label:'Product Usage',   val:82, color:'#22C55E' },
    { label:'Billing Health',  val:91, color:'#22C55E' },
    { label:'Support SLA',     val:76, color:'#0CC9AE' },
  ],
  negative: [
    { label:'Engagement Drop', val:54, color:'#F4A024' },
    { label:'Champion Risk',   val:33, color:'#E84545' },
  ]
};

/* ─── RENDER ACCOUNTS ─── */
function scoreClass(s) {
  if(s >= 60) return 'high';
  if(s >= 35) return 'medium';
  return 'low';
}
function riskColor(r) {
  if(r >= 70) return '#F87171';
  if(r >= 40) return '#FBBF24';
  return '#4ADE80';
}
function tierClass(t) { return t==='Enterprise'?'tier-ent':'tier-mid'; }

const tbody = document.getElementById('acct-tbody');
accounts.forEach(a => {
  const sc = scoreClass(a.score);
  const rc = riskColor(a.risk);
  tbody.innerHTML += `
    <tr style="cursor:pointer" onclick="openDetail(${a.id})">
      <td><div class="acct-name">${a.name}</div><div class="acct-arr">Renewal in ${a.renewal}</div></td>
      <td><span class="score-pill ${sc}">${a.score}</span></td>
      <td>
        <div class="risk-bar-wrap">
          <div class="risk-bar"><div class="risk-fill" style="width:${a.risk}%;background:${rc};height:6px;border-radius:3px"></div></div>
          <span style="font-size:.78rem;color:${rc};font-weight:700;width:30px">${a.risk}%</span>
        </div>
      </td>
      <td style="color:#CBD5E1;font-weight:600">${a.arr}</td>
      <td><span class="tier-chip ${tierClass(a.tier)}">${a.tier}</span></td>
    </tr>`;
});

/* ─── RENDER CHART ─── */
const chart = document.getElementById('mini-chart');
chartBars.forEach((h,i) => {
  chart.innerHTML += `
    <div class="bar-wrap">
      <div class="bar" style="height:${(h/100)*52}px"></div>
      <div class="bar-label">${chartLabels[i]}</div>
    </div>`;
});

/* ─── RENDER SIGNALS ─── */
const sigList = document.getElementById('signal-list');
signals.forEach(s => {
  sigList.innerHTML += `
    <div class="signal-item">
      <div class="signal-icon ${s.type}">${s.icon}</div>
      <div>
        <div class="signal-title">${s.title}</div>
        <div class="signal-desc">${s.desc}</div>
      </div>
      <div class="signal-meta">${s.time}</div>
    </div>`;
});

/* ─── RENDER PLAYBOOKS ─── */
const pbList = document.getElementById('playbook-list');
playbooks.forEach(p => {
  pbList.innerHTML += `
    <div class="playbook-item">
      <div class="pb-num">${p.num}</div>
      <div class="pb-label">${p.label}</div>
      <button class="pb-action" onclick="event.stopPropagation();alert('Playbook ${p.num} triggered. CSM notified via Slack.')">Run</button>
    </div>`;
});

/* ─── DETAIL PANEL ─── */
function openDetail(id) {
  const panel = document.getElementById('detail-panel');
  const content = document.getElementById('dp-content');

  if(id === 'new') {
    content.innerHTML = `
      <div class="dp-title" style="margin-top:8px">New Playbook</div>
      <div class="dp-arr">Select an account and action</div>
      <div class="dp-section">
        <div class="dp-section-title">Quick Actions</div>
        ${playbooks.map(p=>`<div class="rec-item"><strong>Step ${p.num}:</strong> ${p.label}</div>`).join('')}
      </div>`;
    panel.classList.add('open'); return;
  }

  const a = accounts.find(x=>x.id===id);
  if(!a) return;

  const drPos = drivers.positive.map(d=>`
    <div class="driver-row">
      <div class="driver-label">${d.label}</div>
      <div class="driver-bar-wrap"><div class="driver-fill" style="width:${d.val}%;background:${d.color};height:8px;border-radius:4px"></div></div>
      <div class="driver-val" style="color:${d.color}">${d.val}</div>
    </div>`).join('');

  const drNeg = drivers.negative.map(d=>`
    <div class="driver-row">
      <div class="driver-label">${d.label}</div>
      <div class="driver-bar-wrap"><div class="driver-fill" style="width:${d.val}%;background:${d.color};height:8px;border-radius:4px"></div></div>
      <div class="driver-val" style="color:${d.color}">${d.val}</div>
    </div>`).join('');

  content.innerHTML = `
    <div class="dp-title" style="margin-top:8px">${a.name}</div>
    <div class="dp-arr">${a.arr} ARR · ${a.tier} · Renewal in ${a.renewal}</div>

    <div style="display:flex;gap:12px;margin-top:16px">
      <div style="flex:1;text-align:center;padding:12px;background:rgba(255,255,255,.04);border-radius:10px">
        <div style="font-size:1.8rem;font-family:'DM Serif Display',serif;color:${riskColor(100-a.score)}">${a.score}</div>
        <div style="font-size:.72rem;color:var(--muted)">Health Score</div>
      </div>
      <div style="flex:1;text-align:center;padding:12px;background:rgba(255,255,255,.04);border-radius:10px">
        <div style="font-size:1.8rem;font-family:'DM Serif Display',serif;color:${riskColor(a.risk)}">${a.risk}%</div>
        <div style="font-size:.72rem;color:var(--muted)">Churn Risk</div>
      </div>
    </div>

    <div class="dp-section">
      <div class="dp-section-title">Score Drivers (SHAP Explainability)</div>
      <div style="font-size:.72rem;color:var(--teal2);margin-bottom:8px">Positive factors</div>
      ${drPos}
      <div style="font-size:.72rem;color:var(--red);margin-top:10px;margin-bottom:8px">Risk factors</div>
      ${drNeg}
    </div>

    <div class="dp-section">
      <div class="dp-section-title">AI Recommendations</div>
      <div class="rec-item"><strong>Priority 1:</strong> Schedule executive call within 48h to address engagement drop.</div>
      <div class="rec-item"><strong>Priority 2:</strong> Assign dedicated CSM for onboarding of unused features.</div>
      <div class="rec-item"><strong>Priority 3:</strong> Prepare commercial flexibility memo for renewal negotiation.</div>
    </div>

    <div class="dp-section">
      <div class="dp-section-title">Data Sources</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${['CRM','Telemetry','Support Tickets','Billing','NPS Survey'].map(s=>`<span class="badge badge-teal">${s}</span>`).join('')}
      </div>
    </div>

    <div style="margin-top:18px">
      <button class="btn btn-primary" style="width:100%" onclick="alert('Playbook launched for ${a.name}. Slack notification sent to CSM.')">
        Launch Intervention Playbook ▶
      </button>
    </div>`;

  panel.classList.add('open');
}

function closeDetail() {
  document.getElementById('detail-panel').classList.remove('open');
}

/* ─── NAV ─── */
function setPage(el, page) {
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  const titles = {
    portfolio: 'Portfolio Overview',
    signals:   'Live Risk Signals',
    playbooks: 'Intervention Playbooks',
    pipeline:  'Data Pipeline',
    settings:  'Settings'
  };
  document.getElementById('page-title').textContent = titles[page] || page;
}

/* click outside detail to close */
document.addEventListener('click', e=>{
  const dp = document.getElementById('detail-panel');
  if(dp.classList.contains('open') && !dp.contains(e.target)) {
    const rows = document.querySelectorAll('.acct-table tr');
    const sigs = document.querySelectorAll('.signal-item');
    const btns = document.querySelectorAll('.btn-primary, .playbook-item');
    const inside = [...rows,...sigs,...btns].some(r=>r.contains(e.target));
    if(!inside) closeDetail();
  }
});
</script>
</body>
</html>
